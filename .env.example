# ============================================================
# Bad Decision Marketing — Environment Variables
# ============================================================
# This is a marketing site — most env vars are optional.
# Copy to .env.local for local dev. Set in Vercel for prod.
# ============================================================

# Public site URL (used for SEO, sitemap, OG images)
# Local dev: http://localhost:3000
# Production: https://baddecision.app
NEXT_PUBLIC_SITE_URL=https://baddecision.app

# Optional: PostHog for product analytics + feature flags
# Get from https://posthog.com (free up to 1M events/mo)
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Optional: Sentry for error tracking
# Get from https://sentry.io (free tier)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=

# Optional: Dashboard URL (for "Sign In" / "Get Started" CTAs)
# Defaults to https://dashboard.baddecision.app
NEXT_PUBLIC_DASHBOARD_URL=https://dashboard.baddecision.app

# Optional: Support email (shown in footer + contact page)
# Defaults to support@baddecision.app
NEXT_PUBLIC_SUPPORT_EMAIL=support@baddecision.app

# Optional: Contact form submission endpoint
# If set, the contact form will POST here. Otherwise it shows a mailto link.
# CONTACT_FORM_ENDPOINT=
